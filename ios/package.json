{
  "name": "notes-app-ios",
  "version": "1.0.0",
  "description": "Notes App - iOS (Capacitor)",
  "scripts": {
    "build": "cp -r ../web/* www/",
    "sync": "npx cap sync ios",
    "open": "npx cap open ios",
    "start": "npm run build && npm run sync && npm run open",
    "postinstall": "node patches/fix-native-run-simulator.js"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/local-notifications": "^6.0.0",
    "capacitor-calendar": "file:plugins/capacitor-calendar"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "typescript": "^5.9.3"
  }
}
